# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# ============================================================

# Supabase — get from: https://app.supabase.com/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...          # Anon / public key (safe to expose)
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # Service role secret — KEEP SECRET, server-side only

# Gmail SMTP (Nodemailer)
# Requires Gmail 2FA enabled + App Password from:
# https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx        # App Password, NOT your Gmail login password

# Email address that receives new lead notifications
SMTP_TO=contact@careerambitioneducation.com

# Port — Railway sets this automatically. Only needed for local dev.
PORT=3000

# CAE AI Chatbot — Railway hosted embed widget
NEXT_PUBLIC_CHATBOT_URL=https://web-production-a532a.up.railway.app
